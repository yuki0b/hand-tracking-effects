"/><link href="https://c.aps.amazon-adsystem.com" rel="preconnect"/><link as="script" href="https://accounts.google.com/gsi/client?hl=ko" nonce="bbbbdea5c4338b056423444276d4cfee" rel="preload"/><link href="/manifest.json" rel="manifest"/><meta content="Pinterest" name="application-name"/><meta content="#ffffff" name="msapplication-TileColor"/><meta content="https://s.pinimg.com/webapp/logo_transparent_144x144-3da7a67b.png" name="msapplication-TileImage"/><meta content="origin" name="referrer"/><meta content="274266067164" property="fb:app_id"/><meta content="Pinterest" property="og:site_name"/><script nonce="bbbbdea5c4338b056423444276d4cfee">
          let cspReportsCount = 0;
          document.addEventListener('securitypolicyviolation', async (event) => {
            if (event.originalPolicy.includes('report-uri') || cspReportsCount >= 500) {
              return;
            }
            cspReportsCount += 1;
            await fetch('/_/_/csp_report/', {
              method: 'POST',
              body: JSON.stringify({
                'csp-report': {
                  'blocked-uri': event.blockedURI,
                  'column-number': event.columnNumber,
                  disposition: event.disposition,
                  'document-uri': event.documentURI,
                  'effective-directive': event.effectiveDirective,
                  'line-number': event.lineNumber,
                  'original-policy': event.originalPolicy,
                  referrer: event.referrer,
                  sample: event.sample,
                  'source-file': event.sourceFile,
                  'status-code': event.statusCode,
                  'violated-directive': event.violatedDirective,
                  'is-metatag': true,
                },
              }),
            });
          });
